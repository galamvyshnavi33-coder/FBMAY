package StepDefination;


import Allpages.LoginpageC3;
import io.cucumber.java.en.And;
import io.cucumber.java.en.Given;
import io.cucumber.java.en.Then;
import io.cucumber.java.en.When;

public class LoginC3 extends LoginpageC3
{   
	@Given("user is on login page")
	public static void userisonloginpage() throws InterruptedException
	{
		browserInitilization();
	}
	@When("user enters valid username {string}")
	public static void userentersvalidusername(String emailid)
	{
		Enter_email(emailid);
	}
	@Given("user enters valid usernameM \"([^\"]*)\"$")
	public static void userentersvalidusernameM(String emailid)
	{
		Enter_email(emailid);
	}
	@When("user enters valid passwordM \"([^\"]*)\"$")
	public static void userentersvalidpasswordM(String password)
	{
		Enter_password(password);
	}
	@And("user enters valid password {string}")
	public static void userentersvalidpassword(String password)
	{
		Enter_password(password);
	}
	@Then("user should be able to see error message")
	public static void usershouldbeabletoseeerrormessage()
	{
		if(usershouldbeabletoseeerror().equals("The passwoprd you've entered is incorrect"))
		{
			System.out.print("pass");
			System.out.print(usershouldbeabletoseeerror());
			
		}
		else
		{
			System.out.print("fail");
			System.out.print(usershouldbeabletoseeerror());
		}
	}
	@And("clicks on submit button")
	public static void clicksonsubmitbutton()
	{
		buttonlogin();
	}
}
